# ============================================================
# Sportleader Academy — Environment Variables
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
# Then edit .env with real values.
#
# NEVER commit .env to version control.
# ============================================================

# Flask environment: development | production | testing
# REQUIRED. Omitting this defaults to production (strict mode).
FLASK_ENV=production

# Flask session encryption secret.
# REQUIRED in production. Must be ≥ 32 characters.
# Generate a strong one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# PostgreSQL connection URL.
# REQUIRED in production. SQLite is blocked in production mode.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://sportleader:password@localhost:5432/sportleader_academy

# Anthropic API key for the AI mentor chat (claude-sonnet).
# Optional — chat feature degrades gracefully if not set.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Rate limiter backend storage.
# Optional — defaults to in-memory (not shared across workers).
# For multi-worker Gunicorn, use Redis:
#   LIMITER_STORAGE_URI=redis://localhost:6379/0
# LIMITER_STORAGE_URI=memory://

# ── Development only (FLASK_ENV=development) ──────────────
# In development mode, DATABASE_URL may be omitted to use a
# local SQLite file instead of PostgreSQL.
# SESSION_SECRET may also be omitted (an insecure fallback is used).
